{
  "name": "ka-notifications",
  "version": "3",
  "description": "Khan Academy Notifications, no Firefox.",
  "scripts": {
    "start": "node scripts/build.mjs --mode=development --watch",
    "dev": "node scripts/build.mjs --mode=development",
    "prod": "node scripts/build.mjs --mode=production",
    "lint": "eslint src/ts/*.ts src/utils/*.ts",
    "format": "prettier --write \"src/**/*.(ts|css|html)\" \"src/manifest.json\" \"scripts/**\"",
    "release": "node scripts/release.mjs"
  },
  "repository": "git+https://github.com/eliasmurcray/ka-notifications.git",
  "keywords": [
    "chrome-extension",
    "khan-academy"
  ],
  "author": "Elias Murcray",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eliasmurcray/ka-notifications/issues"
  },
  "homepage": "https://github.com/eliasmurcray/ka-notifications#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/ace": "^0.0.52",
    "@types/html-webpack-plugin": "^3.2.9",
    "archiver": "^7.0.1",
    "chrome-types": "^0.1.385",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "eslint": "^9.39.1",
    "fs-extra": "^11.3.2",
    "html-webpack-plugin": "^5.6.4",
    "keysub": "^0.1.2",
    "mini-css-extract-plugin": "^2.9.4",
    "prettier": "^3.6.2",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
  "dependencies": {
    "@craftamap/esbuild-plugin-html": "^0.9.0",
    "ace-builds": "^1.43.4",
    "chokidar": "^4.0.3",
    "esbuild": "^0.25.12"
  }
}
