{
  "name": "ka-notifications",
  "version": "3",
  "description": "Khan Academy Notifications, no Firefox.",
  "scripts": {
    "dev": "webpack --config webpack.dev.mjs",
    "watch": "webpack --config webpack.dev.mjs --watch",
    "build": "webpack --config webpack.prod.mjs",
    "lint": "eslint src/ts/*.ts src/utils/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"src/manifest.json\" \"webpack.dev.mjs\" \"webpack.prod.mjs\" \"scripts/**\"",
    "release": "node scripts/release.mjs"
  },
  "repository": "git+https://github.com/eliasmurcray/ka-notifications.git",
  "keywords": [
    "chrome-extension",
    "khan-academy"
  ],
  "author": "Elias Murcray",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eliasmurcray/ka-notifications/issues"
  },
  "homepage": "https://github.com/eliasmurcray/ka-notifications#readme",
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/ace": "^0.0.52",
    "@types/html-webpack-plugin": "^3.2.6",
    "archiver": "^5.3.1",
    "chrome-types": "^0.1.231",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "eslint": "^9.7.0",
    "fs-extra": "^11.1.1",
    "html-webpack-plugin": "^5.5.3",
    "mini-css-extract-plugin": "^2.7.6",
    "prettier": "^3.1.1",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.10",
    "ts-loader": "^9.4.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^7.17.0",
    "webpack": "^5.88.1",
    "webpack-cli": "^5.1.4"
  }
}
